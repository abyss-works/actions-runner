# GitHub Actions Runner — 사용자 환경변수 설정

# ── 등록 설정 ─────────────────────────
# URL: https://github.com/{GITHUB_ORG}/{GITHUB_REPO} (저장소 레벨)
#      GITHUB_REPO를 비우면 https://github.com/{GITHUB_ORG} (조직 레벨)
# 조직/저장소 정보 (기본값: abyss-works, "")
GITHUB_ORG=
GITHUB_REPO=

# 러너 이름 (기본값: runner)
RUNNER_NAME=

# 러너 라벨 (기본값: self-hosted)
RUNNER_LABELS=

# 러너 그룹 (조직 레벨에서만 유효, 비우면 생략)
RUNNER_GROUP=

# Docker Compose - project name (Volume/Network prefix 격리)
COMPOSE_PROJECT_NAME=actions-runner

# ── 토큰(필수) ──────────────────────────────
# API 토큰 (저장소 레벨):
#   echo "RUNNER_TOKEN=$(gh api --method POST /repos/${GITHUB_ORG}/${GITHUB_REPO}/actions/runners/registration-token --jq '.token')" >> .env
#
# API 토큰 (조직 레벨):
#   echo "RUNNER_TOKEN$(gh api --method POST /orgs/${GITHUB_ORG}/actions/runners/registration-token --jq '.token')" >> .env
# RUNNER_TOKEN=